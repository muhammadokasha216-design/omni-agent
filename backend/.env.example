# OSE — Omni-System Executive Backend Configuration
# Copy this file to .env and populate with your credentials

# API Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# Database Configuration (optional)
DATABASE_URL=

# Database Connection Pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# AI Configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Security
API_KEY_SECRET=your-secret-key-here-change-in-production
SESSION_TIMEOUT=3600

# Feature Flags
ENABLE_REALTIME=true
ENABLE_AGENT_ORCHESTRATION=true
ENABLE_MARKET_STREAMING=true

# Allow test credentials (set to false in production)
ALLOW_TEST_CREDENTIALS=false
